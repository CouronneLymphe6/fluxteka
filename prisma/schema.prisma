// Flowteka — Prisma Schema
// SQLite for local dev, PostgreSQL for production

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  name              String
  avatar            String?
  bio               String?
  github_url        String?
  website_url       String?
  role              String    @default("buyer")
  stripe_account_id String?
  email_verified    Boolean   @default(false)
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt
  workflows         Workflow[]
  reviews           Review[]
  purchases         Purchase[]
  saved_workflows   SavedWorkflow[]
  reports           Report[]

  @@index([email])
  @@index([role])
}

model Workflow {
  id                  String    @id @default(uuid())
  slug                String    @unique
  title               String
  description_fr      String
  description_en      String?
  description_es      String?
  description_de      String?
  description_it      String?
  how_to_use          String?
  prerequisites       String?
  tool                String
  tools_connected     String    @default("[]") // JSON array stored as string
  category            String
  tags                String    @default("[]") // JSON array stored as string
  source_url          String?
  source_type         String?
  source_stars        Int       @default(0)
  source_views        Int       @default(0)
  price               Float     @default(0)
  is_premium          Boolean   @default(false)
  author_id           String
  author              User      @relation(fields: [author_id], references: [id])
  score_total         Float     @default(5)
  score_users         Float     @default(5)
  score_popularity    Float     @default(5)
  score_freshness     Float     @default(10)
  score_reports       Float     @default(10)
  verified_at         DateTime?
  last_checked_at     DateTime  @default(now())
  status              String    @default("pending")
  file_url            String?
  thumbnail_url       String?
  views               Int       @default(0)
  downloads           Int       @default(0)
  indexing_source     String?
  raw_content         String?
  duplicate_of        String?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt
  reviews             Review[]
  purchases           Purchase[]
  saved_by            SavedWorkflow[]
  reports             Report[]

  @@index([slug])
  @@index([tool])
  @@index([category])
  @@index([status])
  @@index([score_total])
  @@index([created_at])
  @@index([source_url])
  @@index([indexing_source])
}

model Review {
  id          String   @id @default(uuid())
  workflow_id String
  workflow    Workflow  @relation(fields: [workflow_id], references: [id], onDelete: Cascade)
  user_id     String
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  rating      Int
  comment     String?
  created_at  DateTime @default(now())

  @@unique([workflow_id, user_id])
  @@index([workflow_id])
}

model Purchase {
  id                String   @id @default(uuid())
  workflow_id       String
  workflow          Workflow @relation(fields: [workflow_id], references: [id])
  buyer_id          String
  buyer             User     @relation(fields: [buyer_id], references: [id])
  stripe_payment_id String   @unique
  amount            Float
  commission        Float
  seller_amount     Float
  status            String   @default("completed")
  created_at        DateTime @default(now())

  @@index([buyer_id])
  @@index([workflow_id])
}

model SavedWorkflow {
  id          String   @id @default(uuid())
  user_id     String
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  workflow_id String
  workflow    Workflow  @relation(fields: [workflow_id], references: [id], onDelete: Cascade)
  created_at  DateTime @default(now())

  @@unique([user_id, workflow_id])
  @@index([user_id])
}

model Report {
  id              String   @id @default(uuid())
  workflow_id     String
  workflow        Workflow @relation(fields: [workflow_id], references: [id], onDelete: Cascade)
  user_id         String
  user            User     @relation(fields: [user_id], references: [id])
  reason          String
  details         String?
  resolved        Boolean  @default(false)
  created_at      DateTime @default(now())

  @@index([workflow_id])
  @@index([resolved])
}

model AffiliateClick {
  id          String   @id @default(uuid())
  tool        String
  workflow_id String?
  user_id     String?
  ip_hash     String?
  created_at  DateTime @default(now())

  @@index([tool])
  @@index([created_at])
}

model AffiliateLink {
  id         String   @id @default(uuid())
  tool       String   @unique
  url        String
  label      String
  active     Boolean  @default(true)
  updated_at DateTime @updatedAt
}

model PartnerSubscription {
  id                     String   @id @default(uuid())
  agency_id              String   @unique
  stripe_subscription_id String   @unique
  status                 String   @default("active")
  expires_at             DateTime
  created_at             DateTime @default(now())
}

model Setting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  updated_at  DateTime @updatedAt
}

model PipelineLog {
  id                  String   @id @default(uuid())
  source              String
  run_at              DateTime @default(now())
  status              String
  found               Int      @default(0)
  new                 Int      @default(0)
  duplicates_url      Int      @default(0)
  duplicates_content  Int      @default(0)
  duplicates_title    Int      @default(0)
  errors              Int      @default(0)
  error_detail        String?
  duration_ms         Int      @default(0)
  tokens_input        Int      @default(0)
  tokens_output       Int      @default(0)
  estimated_cost_usd  Float    @default(0)

  @@index([source])
  @@index([run_at])
}

model CrawledUrl {
  id                  String   @id @default(uuid())
  url                 String   @unique
  url_normalized      String   @unique
  content_fingerprint String?
  source              String
  workflow_id         String?
  crawled_at          DateTime @default(now())
  status              String   @default("indexed")

  @@index([url])
  @@index([url_normalized])
  @@index([content_fingerprint])
  @@index([source])
  @@index([crawled_at])
}

model SmokeTestLead {
  id           String   @id @default(uuid())
  type         String
  email        String
  name         String?
  company      String?
  website      String?
  message      String?
  budget       String?
  tool         String?
  notified     Boolean  @default(false)
  converted    Boolean  @default(false)
  created_at   DateTime @default(now())

  @@index([type])
  @@index([email])
  @@index([created_at])
}
